//@version=6
strategy("加密大漂亮双线反转 · S级会员 · v6",
     overlay              = true,
     initial_capital      = 10000,
     default_qty_value    = 1,
     default_qty_type     = strategy.percent_of_equity,
     currency             = currency.NONE,
     pyramiding           = 100,
     calc_on_every_tick   = false,
     max_lines_count      = 500,
     max_boxes_count      = 500,
     max_labels_count     = 500)

// ========== 参数 ==========
G0 = "⓪ 持仓行为"
posMode = input.string("立即反手", "持仓行为模式",
     options=["忽略反向信号", "立即反手", "止损收紧到保本", "全部开仓叠加(1000元/单)"], group=G0,
     tooltip="忽略=持单中不开新单。立即反手=平掉再反向。止损保本=不开新单但把当前单SL拉到入场价。全部叠加=每个信号都开1000元，同向叠加。")
stackQty = input.float(1000, "叠加模式单笔金额(元)", minval=10, group=G0,
     tooltip="仅在全部开仓叠加模式下生效")

G1 = "① 形态识别"
minBodyToTotalRatio = input.float(0.5, "最小实体占比 m",
     minval=0.1, maxval=1.0, step=0.05, group=G1)

G3 = "② 止损"
stopLossRatioLong = input.float(0.02, "多单止损缓冲倍数",
     minval=0.0, maxval=2.0, step=0.01, group=G3,
     tooltip="多单SL = B/C最低 - (入场 - B/C最低) × 该倍数。0=贴最低；0.02=往外加2%初始风险")
stopLossRatioShort = input.float(0.02, "空单止损缓冲倍数",
     minval=0.0, maxval=2.0, step=0.01, group=G3,
     tooltip="空单SL = B/C最高 + (B/C最高 - 入场) × 该倍数")

G4 = "③ 止盈"
takeProfitMultiplier = input.float(2.0, "止盈振幅倍数",
     minval=0.5, maxval=10.0, step=0.5, group=G4)

G5 = "④ 显示"
showPattern   = input.bool(false, "显示形态识别小三角", group=G5)
showInfoPanel = input.bool(true,  "显示右上角信息面板",  group=G5)

// ========== 工具 ==========
typicalPrice(h, l, c) => (h + l + c) / 3
bodyToTotalRatio(o, h, l, c) => math.abs(c - o) / math.max(math.abs(h - l), syminfo.mintick)
isValidBody(o, h, l, c) => bodyToTotalRatio(o, h, l, c) >= minBodyToTotalRatio
typicalInRange(t, hi, lo) => t >= lo and t <= hi

// ========== 状态 ==========
var float bullishStopRef = na
var float bearishStopRef = na
var float bullishTpRange = na
var float bearishTpRange = na
var int   bullishBar     = na
var int   bearishBar     = na

// ========== 形态识别 + 立即下单（下一根开盘成交）==========
if barstate.isconfirmed
    tp2 = typicalPrice(high[1], low[1], close[1])
    tp3 = typicalPrice(high[0], low[0], close[0])
    validBodies   = isValidBody(open[1], high[1], low[1], close[1]) and isValidBody(open[0], high[0], low[0], close[0])
    validTypicals = typicalInRange(tp2, high[0], low[0]) and typicalInRange(tp3, high[1], low[1])

    bullPat = validBodies and validTypicals and tp2 < low[2]
    bearPat = validBodies and validTypicals and tp2 > high[2]

    if bullPat
        bullishBar := bar_index
        shouldEnter = false
        if posMode == "忽略反向信号"
            if strategy.position_size == 0
                shouldEnter := true
        else if posMode == "立即反手"
            if strategy.position_size <= 0
                shouldEnter := true
        else if posMode == "止损收紧到保本"
            if strategy.position_size == 0
                shouldEnter := true
            else if strategy.position_size < 0
                bearishStopRef := strategy.position_avg_price
        else if posMode == "全部开仓叠加(1000元/单)"
            if strategy.position_size >= 0
                shouldEnter := true
        if shouldEnter
            bullishStopRef := math.min(low[1], low[0])
            bullishTpRange := math.max(high[1] - low[1], high[0] - low[0])
            if posMode == "全部开仓叠加(1000元/单)"
                strategy.entry("多", strategy.long, qty = stackQty / close)
            else
                strategy.entry("多", strategy.long)

    if bearPat
        bearishBar := bar_index
        shouldEnter = false
        if posMode == "忽略反向信号"
            if strategy.position_size == 0
                shouldEnter := true
        else if posMode == "立即反手"
            if strategy.position_size >= 0
                shouldEnter := true
        else if posMode == "止损收紧到保本"
            if strategy.position_size == 0
                shouldEnter := true
            else if strategy.position_size > 0
                bullishStopRef := strategy.position_avg_price
        else if posMode == "全部开仓叠加(1000元/单)"
            if strategy.position_size <= 0
                shouldEnter := true
        if shouldEnter
            bearishStopRef := math.max(high[1], high[0])
            bearishTpRange := math.max(high[1] - low[1], high[0] - low[0])
            if posMode == "全部开仓叠加(1000元/单)"
                strategy.entry("空", strategy.short, qty = stackQty / close)
            else
                strategy.entry("空", strategy.short)

// ========== 出场 ==========
var float curSL = na
var float curTP = na

if strategy.position_size > 0
    avg = strategy.position_avg_price
    curSL := bullishStopRef - (avg - bullishStopRef) * stopLossRatioLong
    curTP := avg + bullishTpRange * takeProfitMultiplier
    strategy.exit("多出", from_entry="多", stop=curSL, limit=curTP)

if strategy.position_size < 0
    avg = strategy.position_avg_price
    curSL := bearishStopRef + (bearishStopRef - avg) * stopLossRatioShort
    curTP := avg - bearishTpRange * takeProfitMultiplier
    strategy.exit("空出", from_entry="空", stop=curSL, limit=curTP)

// ========== 形态小三角（可关）==========
plotshape(showPattern and bar_index == bullishBar ? low : na,
     "形态-多", shape.triangleup, location.belowbar, color=color.new(color.green, 60), size=size.tiny)
plotshape(showPattern and bar_index == bearishBar ? high : na,
     "形态-空", shape.triangledown, location.abovebar, color=color.new(color.red, 60), size=size.tiny)

// ========== 多笔交易可视化 ==========
var array<int>   entryBars  = array.new<int>()
var array<line>  tradeLines = array.new<line>()
var array<line>  slLinesArr = array.new<line>()
var array<float> slPrices   = array.new<float>()
var int prevClosed = 0

// 1. 平仓
if strategy.closedtrades > prevClosed
    for i = prevClosed to strategy.closedtrades - 1
        eb_c = strategy.closedtrades.entry_bar_index(i)
        xb   = strategy.closedtrades.exit_bar_index(i)
        xp   = strategy.closedtrades.exit_price(i)
        pnl  = strategy.closedtrades.profit(i)

        if array.size(entryBars) > 0
            for j = 0 to array.size(entryBars) - 1
                if array.get(entryBars, j) == eb_c
                    tl  = array.get(tradeLines, j)
                    sln = array.get(slLinesArr, j)
                    slP = array.get(slPrices, j)

                    line.set_xy2(tl, xb, xp)
                    line.set_x2(sln, xb)

                    isSLHit = math.abs(xp - slP) < syminfo.mintick * 3
                    if isSLHit
                        line.set_style(sln, line.style_solid)
                        line.set_width(sln, 2)

                    isWin = pnl > 0
                    label.new(xb, xp, isWin ? "✓" : "✗",
                         yloc      = yloc.price,
                         style     = label.style_none,
                         textcolor = isWin ? color.new(color.lime, 0) : color.new(color.red, 0),
                         size      = size.large)

                    array.remove(entryBars, j)
                    array.remove(tradeLines, j)
                    array.remove(slLinesArr, j)
                    array.remove(slPrices, j)
                    break
    prevClosed := strategy.closedtrades

// 2. 新开仓
if strategy.opentrades > 0
    for i = 0 to strategy.opentrades - 1
        eb = strategy.opentrades.entry_bar_index(i)
        found = false
        if array.size(entryBars) > 0
            for j = 0 to array.size(entryBars) - 1
                if array.get(entryBars, j) == eb
                    found := true
                    break
        if not found
            ep = strategy.opentrades.entry_price(i)
            isLong = strategy.opentrades.size(i) > 0
            sl = isLong ? bullishStopRef - (ep - bullishStopRef) * stopLossRatioLong :
                          bearishStopRef + (bearishStopRef - ep) * stopLossRatioShort

            tl = line.new(eb, ep, bar_index, ep,
                 color = isLong ? color.new(color.green, 0) : color.new(color.red, 0),
                 width = 2)
            sln = line.new(eb, sl, bar_index, sl,
                 color = color.new(color.yellow, 0),
                 width = 1, style = line.style_dashed)

            label.new(eb, ep, isLong ? "▲" : "▼",
                 yloc      = yloc.price,
                 style     = label.style_none,
                 textcolor = isLong ? color.new(color.lime, 0) : color.new(color.red, 0),
                 size      = size.large)

            array.push(entryBars, eb)
            array.push(tradeLines, tl)
            array.push(slLinesArr, sln)
            array.push(slPrices, sl)

// 3. 持仓中：延伸 + 同步 SL
if strategy.opentrades > 0 and array.size(tradeLines) > 0
    for j = 0 to array.size(tradeLines) - 1
        tl  = array.get(tradeLines, j)
        sln = array.get(slLinesArr, j)
        line.set_x2(tl, bar_index)
        line.set_y2(tl, close)
        line.set_x2(sln, bar_index)
        if not na(curSL)
            line.set_y1(sln, curSL)
            line.set_y2(sln, curSL)
            array.set(slPrices, j, curSL)

// ========== 平仓后清理（仅 curSL/curTP，refs 不动）==========
if strategy.position_size == 0
    curSL := na
    curTP := na

// ========== 信息面板 ==========
var table infoPanel = table.new(position.top_right, 2, 8,
     bgcolor=color.new(color.black, 30), border_width=1, border_color=color.gray)

f_row(row, lab, val, valColor) =>
    table.cell(infoPanel, 0, row, lab, text_color=color.white,  text_size=size.small, bgcolor=color.new(color.black, 80))
    table.cell(infoPanel, 1, row, val, text_color=valColor,     text_size=size.small)

if showInfoPanel and barstate.islast
    posStr = strategy.position_size > 0 ? "持多 " + str.tostring(strategy.position_size, "#.####") :
             strategy.position_size < 0 ? "持空 " + str.tostring(math.abs(strategy.position_size), "#.####") : "空仓"
    posColor = strategy.position_size > 0 ? color.lime : strategy.position_size < 0 ? color.red : color.gray
    avgStr   = strategy.position_size != 0 ? str.tostring(strategy.position_avg_price, format.mintick) : "—"
    slStr    = not na(curSL) ? str.tostring(curSL, format.mintick) : "—"
    tpStr    = not na(curTP) ? str.tostring(curTP, format.mintick) : "—"
    pnlStr   = strategy.position_size != 0 ? str.tostring(strategy.openprofit, "#.##") : "—"
    pnlColor = strategy.openprofit > 0 ? color.lime : strategy.openprofit < 0 ? color.red : color.gray
    winRate  = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0

    table.cell(infoPanel, 0, 0, "加密大漂亮 · " + posMode, text_color=color.yellow, text_size=size.normal, bgcolor=color.new(color.black, 50))
    table.cell(infoPanel, 1, 0, "v6", text_color=color.gray, text_size=size.small)
    f_row(1, "当前仓位",   posStr,  posColor)
    f_row(2, "开仓笔数",   str.tostring(strategy.opentrades), color.white)
    f_row(3, "入场均价",   avgStr,  color.white)
    f_row(4, "止损价",     slStr,   color.new(color.red, 0))
    f_row(5, "止盈价",     tpStr,   color.new(color.lime, 0))
    f_row(6, "浮动盈亏",   pnlStr,  pnlColor)
    f_row(7, "胜率/总数",  str.tostring(winRate, "#.#") + "% / " + str.tostring(strategy.closedtrades), color.white)
